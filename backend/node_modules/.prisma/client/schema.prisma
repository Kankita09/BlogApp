// This is your Prisma schema file
// Docs: https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  EDITOR
  WRITER
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  avatar    String?  @db.Text
  role      Role     @default(WRITER)
  googleId  String?  @unique @map("google_id") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  posts     Post[]
  auditLogs AuditLog[]

  @@index([email])
  @@index([googleId])
  @@map("users")
}

model Post {
  id             String     @id @default(uuid()) @db.Uuid
  title          String     @db.VarChar(500)
  slug           String     @unique @db.VarChar(500)
  content        Json       @db.JsonB
  status         PostStatus @default(DRAFT)
  seoTitle       String?    @map("seo_title") @db.VarChar(160)
  seoDescription String?    @map("seo_description") @db.VarChar(320)
  excerpt        String?    @db.Text
  bannerImageId  String?    @map("banner_image_id") @db.Uuid
  authorId       String     @map("author_id") @db.Uuid
  publishedAt    DateTime?  @map("published_at") @db.Timestamptz
  scheduledAt    DateTime?  @map("scheduled_at") @db.Timestamptz
  isSponsored    Boolean    @default(false) @map("is_sponsored")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  bannerImage Image?         @relation("PostBanner", fields: [bannerImageId], references: [id], onDelete: SetNull)
  categories  PostCategory[]
  views       PostView[]
  auditLogs   AuditLog[]

  @@index([slug])
  @@index([publishedAt])
  @@index([authorId])
  @@index([status])
  @@map("posts")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  posts PostCategory[]

  @@index([slug])
  @@map("categories")
}

model PostCategory {
  postId     String @map("post_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([postId])
  @@index([categoryId])
  @@map("post_categories")
}

model Image {
  id           String   @id @default(uuid()) @db.Uuid
  cloudinaryId String   @map("cloudinary_id") @db.VarChar(500)
  url          String   @db.Text
  altText      String   @map("alt_text") @db.VarChar(500)
  title        String?  @db.VarChar(500)
  caption      String?  @db.Text
  width        Int?
  height       Int?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  bannerPosts Post[] @relation("PostBanner")

  @@index([cloudinaryId])
  @@map("images")
}

model PostView {
  id       String   @id @default(uuid()) @db.Uuid
  postId   String   @map("post_id") @db.Uuid
  ipHash   String   @map("ip_hash") @db.VarChar(64)
  uaHash   String   @map("ua_hash") @db.VarChar(64)
  viewedAt DateTime @default(now()) @map("viewed_at") @db.Timestamptz

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, ipHash, uaHash])
  @@index([postId])
  @@index([viewedAt])
  @@map("post_views")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String?  @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model AffiliateLink {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique @db.VarChar(255)
  targetUrl String   @map("target_url") @db.Text
  clicks    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([slug])
  @@map("affiliate_links")
}
