# ─── DATABASE (Neon PostgreSQL) ───────────────────────────────────────────────
# Pooled connection — used by Prisma at runtime
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/tcb?sslmode=require&pgbouncer=true&connect_timeout=10"
# Direct connection — used by Prisma migrations only
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/tcb?sslmode=require"

# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
# Allowed origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,https://yourcorporateblog.com"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_64_byte_random_hex_string"
JWT_REFRESH_SECRET="replace_with_different_64_byte_random_hex_string"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# ─── CLOUDINARY ───────────────────────────────────────────────────────────────
# https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_UPLOAD_PRESET="tcb_uploads"

# ─── ISR REVALIDATION ─────────────────────────────────────────────────────────
# Secret shared with Next.js frontend for on-demand ISR revalidation
REVALIDATION_SECRET="replace_with_random_secret"
FRONTEND_URL="http://localhost:3000"

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
